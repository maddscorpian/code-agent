OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=deepseek-coder-v2
OLLAMA_EMBED_MODEL=nomic-embed-text
PROJECTS_CONFIG=./projects.yaml
API_PORT=8765
LOG_LEVEL=INFO

# ── Data paths ────────────────────────────────────────────────────────────────
# AGENT_DATA_ROOT: base directory that contains digests/, graph/, and vector_db/.
# Set this to an absolute path if you want to use pre-generated context from
# another machine or a shared network location (e.g. /mnt/shared/agent-context).
# All three sub-paths below are resolved relative to AGENT_DATA_ROOT when it is set,
# or relative to the repo root when it is not.
# AGENT_DATA_ROOT=/absolute/path/to/context

# Individual overrides — only needed if AGENT_DATA_ROOT is not enough:
CHROMA_PATH=./vector_db
DIGESTS_PATH=./digests
# GRAPH_PATH=./graph/knowledge_graph.json

# Optional: point tiktoken to a local cache directory to avoid SSL download.
# TIKTOKEN_CACHE_DIR=./tiktoken_cache
