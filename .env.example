OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=deepseek-coder-v2
OLLAMA_EMBED_MODEL=nomic-embed-text
PROJECTS_CONFIG=./projects.yaml
API_PORT=8765
LOG_LEVEL=INFO

# ── Data paths ────────────────────────────────────────────────────────────────
# AGENT_DATA_ROOT sets the base directory for ALL generated context artefacts:
#   digests/           — JSON digests per project
#   graph/             — knowledge_graph.json
#   vector_db/         — ChromaDB embeddings
#   api-catalog/       — openapi.json + api-catalog.md
#
# Leave unset to keep everything inside the repo directory (default).
# Set to an absolute path when using pre-generated context from another machine:
#   AGENT_DATA_ROOT=/absolute/path/to/agent-context
#
# AGENT_DATA_ROOT=/absolute/path/to/agent-context

# Individual path overrides (only needed when AGENT_DATA_ROOT is not enough):
CHROMA_PATH=./vector_db
DIGESTS_PATH=./digests
# GRAPH_PATH=./graph/knowledge_graph.json
# API_CATALOG_PATH=./api-catalog

# Optional: point tiktoken to a local cache directory to avoid SSL download.
# TIKTOKEN_CACHE_DIR=./tiktoken_cache
